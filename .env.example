# AI Assistant - Environment Configuration

# === NODE.JS BACKEND ===
NODE_ENV=development
NODE_PORT=5000

# === PYTHON AI SERVICE ===
PYTHON_AI_PORT=8000
PYTHON_AI_HOST=localhost

# === DATABASE ===
MONGODB_URI=mongodb://localhost:27017/ai-assistant
MONGODB_USER=admin
MONGODB_PASSWORD=changeme

# === JWT ===
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# === AUDIO & VOICE ===
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
VOICE_CONFIDENCE_THRESHOLD=0.85
VOICE_ENROLLMENT_SAMPLES=3

# === AI MODELS ===
OPENAI_API_KEY=your_openai_api_key_here
WHISPER_MODEL=base
SPEECHBRAIN_MODEL=spkrec-ecapa-voxceleb

# === SECURITY ===
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=900000  # 15 minutes in ms
VOICE_VERIFICATION_REQUIRED=true

# === VOICE RESPONSE ===
TTS_ENGINE=google  # or espeak
TTS_LANGUAGE=en

# === LOGGING ===
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# === ELECTRON ===
ELECTRON_DEV_TOOLS=true
ELECTRON_PRELOAD_PATH=src/preload/preload.ts

# === CORS ===
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# === AUTH ===
# Set true to allow public signup; otherwise only first user + owner-created accounts
ALLOW_PUBLIC_SIGNUP=false

# === COMMAND WHITELIST ===
# Commands that are allowed to execute without additional confirmation
SAFE_COMMANDS=OPEN_APP,CLOSE_APP,SCREENSHOT

# === DANGEROUS COMMANDS (require confirmation) ===
# These commands will require voice confirmation before execution
DANGEROUS_COMMANDS=DELETE_FILE,SYSTEM_SHUTDOWN,SYSTEM_RESTART
