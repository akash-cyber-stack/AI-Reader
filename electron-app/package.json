{
  "name": "ai-assistant-electron",
  "version": "1.0.0",
  "description": "AI Desktop Assistant - Voice-controlled and secure",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-dev\"",
    "react-start": "react-scripts start",
    "prereact-build": "node scripts/write-env-config.js",
    "react-build": "react-scripts build",
    "build:vercel": "node scripts/write-env-config.js && react-scripts build",
    "electron-dev": "electron .",
    "serve-build": "node scripts/serve-build.js",
    "electron-build": "electron-builder",
    "build": "npm run react-build && npm run electron-build",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "concurrently": "^8.2.2",
    "css-modules-typescript-loader": "^4.0.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.3",
    "wait-on": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.ai-assistant.app",
    "productName": "AI Assistant",
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "public/electron.js",
      "public/preload.js"
    ],
    "directories": {
      "buildResources": "public"
    }
  }
}
